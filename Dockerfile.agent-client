ARG AGENT_CLIENT_BASE_IMAGE=img.ones.pro/dev/xl/agent-client-base:node22-bookworm-jdk8

FROM node:22-bookworm-slim AS build

RUN corepack enable

WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc tsconfig.base.json ./
COPY packages/shared/package.json ./packages/shared/package.json
COPY packages/shared/tsconfig.json ./packages/shared/tsconfig.json
COPY apps/agent-client/package.json ./apps/agent-client/package.json
COPY apps/agent-client/tsconfig.json ./apps/agent-client/tsconfig.json

RUN pnpm install --frozen-lockfile --filter @ones-ai-workflow/agent-client...

COPY packages/shared ./packages/shared
COPY apps/agent-client ./apps/agent-client

RUN pnpm --filter @ones-ai-workflow/shared build
RUN pnpm --filter @ones-ai-workflow/agent-client build
RUN pnpm --filter @ones-ai-workflow/agent-client --prod deploy /prod/agent-client

FROM ${AGENT_CLIENT_BASE_IMAGE}

WORKDIR /app

COPY --from=build /prod/agent-client /app
COPY docker/agent-client/entrypoint.sh /usr/local/bin/agent-client-entrypoint.sh

RUN chmod +x /usr/local/bin/agent-client-entrypoint.sh \
  && chown -R node:node /app /data /codex /claude /usr/local/bin/agent-client-entrypoint.sh

USER node

ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/agent-client-entrypoint.sh"]
CMD ["node", "dist/index.js"]
