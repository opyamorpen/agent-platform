{
  "name": "@ones-ai-workflow/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:prompt-template": "node scripts/generate-prompt-template.mjs",
    "dev": "pnpm run generate:prompt-template && tsx watch src/index.ts",
    "dev:relay": "pnpm run generate:prompt-template && tsx watch src/index.ts",
    "build": "pnpm run generate:prompt-template && esbuild src/index.ts --bundle --platform=node --format=cjs --target=node22 --outfile=dist/index.cjs",
    "typecheck": "pnpm run generate:prompt-template && tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.cjs",
    "test": "pnpm run generate:prompt-template && tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "@ones-ai-workflow/shared": "workspace:^",
    "@ones-open/node-sdk": "^0.0.17",
    "dotenv": "^16.5.0",
    "hono": "^4.7.8",
    "jsonwebtoken": "^9.0.3",
    "log4js": "^6.9.1",
    "micro-key-producer": "^0.8.6",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "esbuild": "^0.27.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
