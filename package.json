{
  "name": "agent-platform",
  "private": true,
  "packageManager": "pnpm@8.15.5",
  "scripts": {
    "dev": "pnpm --parallel --filter @ones-ai-workflow/web --filter @ones-ai-workflow/server dev",
    "dev:ones": "ones dev --command \"pnpm dev:server\" --install",
    "dev:relay": "pnpm --filter @ones-ai-workflow/web run dev:relay",
    "dev:web": "pnpm --filter @ones-ai-workflow/web dev",
    "dev:server": "pnpm --filter @ones-ai-workflow/server dev",
    "dev:agent-client": "pnpm --filter @ones-ai-workflow/agent-client dev",
    "build": "pnpm --filter @ones-ai-workflow/shared build && pnpm --filter @ones-ai-workflow/server build && pnpm --filter @ones-ai-workflow/web build && pnpm --filter @ones-ai-workflow/agent-client build",
    "build:opkx": "ones build --output ./ones-ai-workflow.opkx --command \"pnpm build\"",
    "deploy:opkx": "node scripts/ones-opkx-deploy.mjs",
    "typecheck": "pnpm --filter @ones-ai-workflow/shared typecheck && pnpm --filter @ones-ai-workflow/server typecheck && pnpm --filter @ones-ai-workflow/web typecheck && pnpm --filter @ones-ai-workflow/agent-client typecheck",
    "lint": "eslint . --ext .ts,.tsx",
    "build:hosted": "pnpm build",
    "build:worker": "pnpm --filter @ones-ai-workflow/agent-client build"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.26.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  }
}
